APP_NAME=Laravel
APP_ENV=testing
APP_KEY=base64:E+CMLAovyIFyLA18szH54CRU67weU+s9sbZIpyk/Pgg=
APP_URL=http://localhost

# Localization
APP_LOCALE=fr
APP_FALLBACK_LOCALE=fr
APP_FAKER_LOCALE=en_US

# Performance: Use 4 rounds for hashing passwords instead of 12
BCRYPT_ROUNDS=4

# Database: Pointing to your dedicated test DB
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=notepad_test
DB_USERNAME=root
DB_PASSWORD=Anouar20032005

# Speed & Isolation: Switch from 'database' to 'array' or 'sync'
# This prevents tests from writing session/cache data to the DB
SESSION_DRIVER=array
CACHE_STORE=array
QUEUE_CONNECTION=sync
MAIL_MAILER=array

# Logging & Storage
LOG_CHANNEL=null
FILESYSTEM_DISK=local

# Disable unnecessary tools during tests
PULSE_ENABLED=false
TELESCOPE_ENABLED=false
DEBUGBAR_ENABLED=false

